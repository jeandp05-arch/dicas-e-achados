<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dicas & Achados</title>
  <style>
    body { font-family: Arial, sans-serif; margin:0; padding:0; background:#f5f5f5; color:#2C2C2C; }
    header { background:#FFD700; padding:20px; text-align:center; }
    header h1 { margin:0; color:#2C2C2C; }
    header p { margin:5px 0 0 0; font-weight:bold; }
    nav { background:#2C2C2C; text-align:center; padding:10px; }
    nav a { color:#FFD700; margin:0 10px; text-decoration:none; font-weight:bold; }
    main { padding:20px; max-width:1200px; margin:auto; }
    section { margin-bottom:40px; }
    h2 { color:#2C2C2C; margin-bottom:20px; text-align:center; }
    .produtos { display:flex; flex-wrap:wrap; gap:20px; justify-content:center; }
    .produto { background:#fff; padding:15px; border-radius:8px; width:220px; text-align:center; box-shadow:0 0 10px rgba(0,0,0,0.1);}
    .produto img { max-width:100%; border-radius:8px; }
    .produto h3 { margin:10px 0 5px 0; }
    .produto p { margin:5px 0; }
    .btn { display:inline-block; padding:10px 15px; background:#FFD700; color:#2C2C2C; text-decoration:none; border-radius:5px; margin-top:5px; font-weight:bold; }
    footer { text-align:center; padding:20px; background:#2C2C2C; color:#FFD700; }
    form input, form textarea { padding:8px; width:100%; margin-bottom:10px; border-radius:5px; border:1px solid #ccc; }
    form button { padding:10px 20px; background:#FFD700; color:#2C2C2C; border:none; border-radius:5px; cursor:pointer; font-weight:bold; }
    @media(max-width:600px){ .produtos { flex-direction:column; align-items:center; } }
  </style>
</head>
<body>
  <header>
    <h1>Dicas & Achados</h1>
    <p>Achados incríveis e úteis para você!</p>
  </header>

  <nav>
    <a href="#produtos">Produtos</a>
    <a href="#sobre">Sobre</a>
    <a href="#contato">Contato</a>
  </nav>

  <main>
    <section id="produtos">
      <h2>Produtos em Destaque</h2>
      <div class="produtos">
        <!-- Produto 1 -->
        <div class="produto">
          <img src="https://via.placeholder.com/200x150" alt="Produto 1">
          <h3>Produto 1</h3>
          <p>Descrição curta do produto.</p>
          <p>€19,90</p>
          <a class="btn" href="https://www.paypal.com/cgi-bin/webscr?cmd=_xclick&business=SEU_EMAIL_PAYPAL&item_name=Produto+1&amount=19.90&currency_code=EUR" target="_blank">Comprar</a>
          <a class="btn" href="https://wa.me/SEU_NUMERO" target="_blank">WhatsApp</a>
        </div>
        <!-- Produto 2 -->
        <div class="produto">
          <img src="https://via.placeholder.com/200x150" alt="Produto 2">
          <h3>Produto 2</h3>
          <p>Descrição curta do produto.</p>
          <p>€29,90</p>
          <a class="btn" href="https://www.paypal.com/cgi-bin/webscr?cmd=_xclick&business=SEU_EMAIL_PAYPAL&item_name=Produto+2&amount=29.90&currency_code=EUR" target="_blank">Comprar</a>
          <a class="btn" href="https://wa.me/SEU_NUMERO" target="_blank">WhatsApp</a>
        </div>
        <!-- Produto 3 -->
        <div class="produto">
          <img src="https://via.placeholder.com/200x150" alt="Produto 3">
          <h3>Produto 3</h3>
          <p>Descrição curta do produto.</p>
          <p>€39,90</p>
          <a class="btn" href="https://www.paypal.com/cgi-bin/webscr?cmd=_xclick&business=SEU_EMAIL_PAYPAL&item_name=Produto+3&amount=39.90&currency_code=EUR" target="_blank">Comprar</a>
          <a class="btn" href="https://wa.me/SEU_NUMERO" target="_blank">WhatsApp</a>
        </div>
        <!-- Você pode duplicar até Produto 10 -->
      </div>
    </section>

    <section id="sobre">
      <h2>Sobre a Loja</h2>
      <p>Dicas & Achados é uma loja online dedicada a trazer produtos úteis e surpreendentes que facilitam o dia a dia. Aqui, você encontra achados incríveis testados e selecionados para você!</p>
    </section>

    <section id="contato">
      <h2>Contato</h2>
      <p>Envie sua mensagem ou fale pelo WhatsApp:</p>
      <form>
        <input type="text" placeholder="Nome" required>
        <input type="email" placeholder="E-mail" required>
        <textarea placeholder="Mensagem" required></textarea>
        <button type="submit">Enviar</button>
      </form>
      <p style="margin-top:10px;"><a class="btn" href="https://wa.me/SEU_NUMERO" target="_blank">Falar pelo WhatsApp</a></p>
    </section>
  </main>

  <footer>
    <p>© 2026 Dicas & Achados - Todos os direitos reservados</p>
  </footer>
</body>
</html>
